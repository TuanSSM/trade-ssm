# === Required (analyzer) ===
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# === Market config ===
SYMBOL=BTCUSDT
INTERVAL=15m
CHECK_INTERVAL_SECS=60

# === Execution ===
EXECUTION_MODE=paper
# EXECUTION_MODE=live

# === download-data ===
DAYS=30
DATADIR=user_data

# === backtest ===
# DATAFILE=user_data/BTCUSDT-15m-20260220-20260322.json
CVD_WINDOW=15

# === Correlation pairs (multi-asset RL context) ===
# Comma-separated symbols whose candle data enriches the RL feature vector.
# Example: when trading LINKUSDT, include ETH and BTC for cross-asset context.
# CORRELATION_PAIRS=ETHUSDT,BTCUSDT

# === rl-backtest: correlated pair data files ===
# Format: SYMBOL:path pairs, comma-separated.
# CORR_DATAFILES=ETHUSDT:user_data/ETHUSDT-15m.json,BTCUSDT:user_data/BTCUSDT-15m.json

# === RL config ===
# RL_CONFIG=config/rl-default.toml
# RL_MODE=single
# RL_TIMEFRAME=15m
# MODEL_PATH=models/table_model_best.json

# === Logging ===
RUST_LOG=info
